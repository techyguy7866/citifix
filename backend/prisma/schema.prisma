generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                 Int             @id @default(autoincrement())
  name               String
  email              String?         @unique
  phone              String          @unique
  role               Role            @default(CITIZEN)
  department         String?
  rewardPoints       Int             @default(0)
  complaints            Complaint[]        @relation("UserComplaints")
  assignedComplaints    Complaint[]        @relation("SubAdminComplaints")
  votes                 ComplaintVote[]
  otpRequests           OtpRequest[]
  chatMessages          ChatMessage[]
  slaConfigs            SlaConfig[]
  extensionRequests     ExtensionRequest[] @relation("ExtensionRequests")
  raisedIssues          RaisedIssue[]      @relation("RaisedIssuesByUser")
  assignedRaisedIssues  RaisedIssue[]      @relation("RaisedIssuesAssignedTo")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Complaint {
  id                 Int             @id @default(autoincrement())
  title              String
  description        String
  category           String
  latitude           Float
  longitude          Float
  address            String?
  imageUrl           String?
  status             ComplaintStatus @default(OPEN)
  votes              Int             @default(0)
  anonymous          Boolean         @default(true)
  tweetPosted        Boolean         @default(false)
  escalatedAt        DateTime?
  resolvedAt         DateTime?
  xPostId            String?
  xPostUrl           String?
  xPostStatus        XPostStatus     @default(PENDING)
  xPostAttempts      Int             @default(0)
  lastXPostAttemptAt DateTime?
  xPostError         String?
  assignedDepartment String?
  // Sub-admin assignment
  assignedAdminId    Int?
  assignedAdmin      User?           @relation("SubAdminComplaints", fields: [assignedAdminId], references: [id])
  assignedAt         DateTime?
  slaDeadline        DateTime?
  slaBreached        Boolean         @default(false)
  slaBreach          SlaBreachAction @default(NONE)
  // Project details (set by SuperAdmin at assignment)
  projectAmount      Float?
  warrantyPeriod     Int?
  projectDeadline    DateTime?
  projectNote        String?
  extensionRequests  ExtensionRequest[]
  raisedIssues       RaisedIssue[]
  isOnHold           Boolean         @default(false)
  userId             Int
  user               User            @relation("UserComplaints", fields: [userId], references: [id])
  complaintVotes     ComplaintVote[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ExtensionRequest {
  id            Int                    @id @default(autoincrement())
  complaintId   Int
  complaint     Complaint              @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  requestedById Int
  requestedBy   User                   @relation("ExtensionRequests", fields: [requestedById], references: [id])
  reason        String
  requestedDays Int
  status        ExtensionRequestStatus @default(PENDING)
  reviewNote    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model SlaConfig {
  id            Int      @id @default(autoincrement())
  department    String   @unique
  daysToResolve Int      @default(7)
  updatedById   Int
  updatedBy     User     @relation(fields: [updatedById], references: [id])
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model ComplaintVote {
  id          Int       @id @default(autoincrement())
  complaintId Int
  userId      Int
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([complaintId, userId])
}

model OtpRequest {
  id        Int        @id @default(autoincrement())
  phone     String
  otpCode   String
  purpose   OtpPurpose
  expiresAt DateTime
  used      Boolean    @default(false)
  userId    Int?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
}

model ChatMessage {
  id        Int             @id @default(autoincrement())
  userId    Int
  role      ChatMessageRole
  content   String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

enum Role {
  CITIZEN
  ADMIN
  SUPERADMIN
  SUBADMIN
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  RESOLVED
  ESCALATED
}

enum XPostStatus {
  PENDING
  SENT
  FAILED
}

enum SlaBreachAction {
  NONE
  BADGE_SHOWN
  ESCALATED
  REMINDER_SENT
}

enum OtpPurpose {
  LOGIN
  REGISTER
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum ExtensionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RaisedIssueStatus {
  PENDING
  ASSIGNED
  RESOLVED
}

model RaisedIssue {
  id           Int               @id @default(autoincrement())
  complaintId  Int
  complaint    Complaint         @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  raisedById   Int
  raisedBy     User              @relation("RaisedIssuesByUser", fields: [raisedById], references: [id])
  assignedToId Int?
  assignedTo   User?             @relation("RaisedIssuesAssignedTo", fields: [assignedToId], references: [id])
  title        String
  description  String
  status       RaisedIssueStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}
